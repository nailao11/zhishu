# 复制为 .env 并按需修改

# API 访问 Token（强烈建议设置，否则你的服务谁都能调用）
# 生成方法：openssl rand -hex 32
ZHISHU_API_TOKEN=

# API 监听地址和端口
ZHISHU_API_HOST=0.0.0.0
ZHISHU_API_PORT=8000

# 默认查询天数
ZHISHU_DEFAULT_DAYS=30

# 历史数据与运行记录的保留天数（每天自动滚动清理，超出的删除）
ZHISHU_RETENTION_DAYS=45

# 默认 HTTP/SOCKS5 代理（可选）。后台「代理设置」里保存的值优先级更高。
# 格式： http://user:pass@host:port  或  socks5://user:pass@host:port
# ZHISHU_HTTP_PROXY=

# Cookie 文件路径（一般用默认值就行）
# ZHISHU_COOKIE_FILE=/opt/zhishu/config/cookies.txt

# 数据库路径
# ZHISHU_DB_PATH=/opt/zhishu/data/zhishu.db

# 日志目录
# ZHISHU_LOG_DIR=/opt/zhishu/logs
